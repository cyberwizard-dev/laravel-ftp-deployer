{
    "name": "cyberwizard/laravel-ftp-deployer",
    "description": "Run Laravel Artisan commands on remote servers via FTP and HTTP triggers (useful for hosting without SSH).",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Cyberwizard"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Cyberwizard\\LaravelFtpDeployer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/ftp-deploy"
    ]
}
