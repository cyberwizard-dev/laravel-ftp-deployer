#!/usr/bin/env php
<?php

$autoloadPaths = [
    getcwd() . '/vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];

$loaded = false;
foreach ($autoloadPaths as $file) {
    if (file_exists($file)) {
        require $file;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    die("ERROR: Composer autoloader not found. Please run 'composer install'.\n");
}

use Cyberwizard\LaravelFtpDeployer\RemoteExecutor;

function loadEnv($path)
{
    if (!file_exists($path)) return [];
    $lines = file($path, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    $env = [];
    foreach ($lines as $line) {
        $line = trim($line);
        if (!$line || str_starts_with($line, '#')) continue;
        if (!str_contains($line, '=')) continue;
        list($name, $value) = explode('=', $line, 2);
        $env[trim($name)] = trim($value, '"\' ');
    }
    return $env;
}

$root = getcwd();
$envFile = file_exists($root . '/.env.prod') ? $root . '/.env.prod' : $root . '/.env';
$env = loadEnv($envFile);

$config = [
    'ftp_host' => $env['FTP_HOST'] ?? '',
    'ftp_user' => $env['FTP_USERNAME'] ?? '',
    'ftp_pass' => $env['FTP_PASSWORD'] ?? '',
    'ftp_port' => $env['FTP_PORT'] ?? 21,
    'ftp_root' => $env['FTP_ROOT'] ?? '',
    'app_url' => $env['APP_URL'] ?? '',
];

if (empty($config['ftp_host']) || empty($config['ftp_user'])) {
    die("ERROR: FTP configuration missing in .env or .env.prod\n");
}

$isFirstTime = false;
$customCommandName = null;

if (isset($argv[1])) {
    if ($argv[1] === '--first-time' || $argv[1] === '-f') {
        $isFirstTime = true;
    } elseif ($argv[1] === '--help' || $argv[1] === '-h' || $argv[1] === 'help') {
        displayHelp();
        exit(0);
    } else {
        $customCommandName = $argv[1];
    }
}

function logColor($msg, $color = '37') {
    echo "\033[" . $color . "m" . $msg . "\033[0m\n";
}

function displayHelp() {
    logColor("\nLaravel FTP Deployer", '32');
    echo "Usage:\n";
    echo "  vendor/bin/ftp-deploy [command|option]\n\n";
    echo "Options:\n";
    echo "  -h, --help, help    Display this help message\n";
    echo "  -f, --first-time    Perform a full deployment (ignores manifest)\n\n";
    
    // Attempt to load custom commands for help display
    try {
        $env = loadEnv(file_exists('.env.prod') ? '.env.prod' : '.env');
        $executor = new \Cyberwizard\LaravelFtpDeployer\RemoteExecutor($env);
        $reflection = new \ReflectionClass($executor);
        $prop = $reflection->getProperty('customCommands');
        $customs = $prop->getValue($executor);
        
        if (!empty($customs)) {
            echo "Custom Commands (defined in deploy.json):\n";
            foreach (array_keys($customs) as $cmd) {
                echo "  $cmd\n";
            }
            echo "\n";
        }
    } catch (\Exception $e) {
        // Silently skip if config isn't ready
    }

    echo "Example:\n";
    echo "  vendor/bin/ftp-deploy           # Standard incremental deploy\n";
    echo "  vendor/bin/ftp-deploy db-reset  # Run custom command set\n";
}

try {
    $executor = new RemoteExecutor($config);
    
    if ($customCommandName) {
        $commands = $executor->getCustomCommand($customCommandName);
        if (!$commands) {
            logColor("ERROR: Custom command '$customCommandName' not found in deploy.json", '31');
            exit(1);
        }
        $success = $executor->runCommands($commands);
    } else {
        $success = $executor->deploy($isFirstTime);
    }

    if ($success) {
        logColor("Process finished successfully.", '32');
    } else {
        logColor("Process failed.", '31');
        exit(1);
    }
} catch (\Exception $e) {
    logColor("ERROR: " . $e->getMessage(), '31');
    exit(1);
}
