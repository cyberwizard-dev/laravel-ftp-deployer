#!/usr/bin/env php
<?php

$autoloadPaths = [
    getcwd() . '/vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];

$loaded = false;
foreach ($autoloadPaths as $file) {
    if (file_exists($file)) {
        require $file;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    die("ERROR: Composer autoloader not found. Please run 'composer install'.\n");
}

use Cyberwizard\LaravelFtpDeployer\RemoteExecutor;

// ─── Helpers ──────────────────────────────────────────────────────────────────

function logColor($msg, $color = '37') {
    echo "\033[" . $color . "m" . $msg . "\033[0m\n";
}

function loadEnv($path)
{
    if (!file_exists($path)) return [];
    $lines = file($path, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    $env = [];
    foreach ($lines as $line) {
        $line = trim($line);
        if (!$line || str_starts_with($line, '#')) continue;
        if (!str_contains($line, '=')) continue;
        [$name, $value] = explode('=', $line, 2);
        $env[trim($name)] = trim($value, '"\' ');
    }
    return $env;
}

// ─── Support Banner ───────────────────────────────────────────────────────────

function showBanner(): void
{
    $width = 60;
    $line  = str_repeat('─', $width);

    echo "\n";
    echo "\033[90m┌{$line}┐\033[0m\n";

    // Title
    $title = ' Laravel FTP Deployer ';
    $pad   = (int) floor(($width - strlen($title)) / 2);
    echo "\033[90m│\033[0m"
        . str_repeat(' ', $pad)
        . "\033[1;32m{$title}\033[0m"
        . str_repeat(' ', $width - $pad - strlen($title))
        . "\033[90m│\033[0m\n";

    echo "\033[90m├{$line}┤\033[0m\n";

    // Support lines
    $lines = [
        ['label' => '  If you find this tool useful, consider reaching out:', 'value' => ''],
        ['label' => '', 'value' => ''],
        ['label' => '  📧  Email    ', 'value' => 'eminibest@gmail.com'],
        ['label' => '  💬  WhatsApp ', 'value' => '+2347085307378'],
        ['label' => '', 'value' => ''],
        ['label' => '  Custom deployment solutions available on request.', 'value' => ''],
    ];

    foreach ($lines as ['label' => $label, 'value' => $value]) {
        if ($label === '' && $value === '') {
            echo "\033[90m│\033[0m" . str_repeat(' ', $width) . "\033[90m│\033[0m\n";
            continue;
        }

        if ($value !== '') {
            $content = "\033[33m{$label}\033[0m\033[1;36m{$value}\033[0m";
            // Visible length (strip ANSI codes for padding)
            $visibleLen = strlen($label) + strlen($value);
        } else {
            $content    = "\033[90m{$label}\033[0m";
            $visibleLen = strlen($label);
        }

        $padding = max(0, $width - $visibleLen);
        echo "\033[90m│\033[0m" . $content . str_repeat(' ', $padding) . "\033[90m│\033[0m\n";
    }

    echo "\033[90m└{$line}┘\033[0m\n";
    echo "\n";
}

function showCountdown(int $seconds = 3): void
{
    echo "\033[33mStarting in: \033[0m";
    for ($i = $seconds; $i >= 1; $i--) {
        echo "\033[1;31m{$i}\033[0m";
        if ($i > 1) {
            echo "\033[33m...\033[0m";
            flush();
            sleep(1);
        }
    }
    sleep(1);
    echo "\n\n";
}

// ─── Display banner & countdown (skip for --help) ────────────────────────────

$isHelp = isset($argv[1]) && in_array($argv[1], ['--help', '-h', 'help'], true);

if (!$isHelp) {
    showBanner();
    showCountdown(3);
}

// ─── Config ───────────────────────────────────────────────────────────────────

$root    = getcwd();
$envFile = file_exists($root . '/.env.prod') ? $root . '/.env.prod' : $root . '/.env';
$env     = loadEnv($envFile);

$config = [
    'ftp_host' => $env['FTP_HOST']     ?? '',
    'ftp_user' => $env['FTP_USERNAME'] ?? '',
    'ftp_pass' => $env['FTP_PASSWORD'] ?? '',
    'ftp_port' => $env['FTP_PORT']     ?? 21,
    'ftp_root' => $env['FTP_ROOT']     ?? '',
    'app_url'  => $env['APP_URL']      ?? '',
];

if (empty($config['ftp_host']) || empty($config['ftp_user'])) {
    die("ERROR: FTP configuration missing in .env or .env.prod\n");
}

// ─── Argument parsing ─────────────────────────────────────────────────────────

$isFirstTime       = false;
$dryRun            = false;
$customCommandName = null;

if (isset($argv[1])) {
    $args = array_slice($argv, 1);
    foreach ($args as $arg) {
        if (in_array($arg, ['--first-time', '-f'], true)) {
            $isFirstTime = true;
        } elseif (in_array($arg, ['--dry-run'], true)) {
            $dryRun = true;
        } elseif (in_array($arg, ['--help', '-h', 'help'], true)) {
            displayHelp();
            exit(0);
        } elseif (!$customCommandName && str_starts_with($arg, '-') === false) {
            $customCommandName = $arg;
        }
    }
}

// ─── Help ─────────────────────────────────────────────────────────────────────

function displayHelp(): void
{
    logColor("\nLaravel FTP Deployer", '32');
    echo "Usage:\n";
    echo "  vendor/bin/ftp-deploy [command|option]\n\n";
    echo "Options:\n";
    echo "  -h, --help, help    Display this help message\n";
    echo "  -f, --first-time    Perform a full deployment (ignores manifest, includes vendor/)\n";
    echo "  --dry-run           Show what would be deployed and executed without connecting to the remote server\n\n";

    try {
        $env      = loadEnv(file_exists('.env.prod') ? '.env.prod' : '.env');
        $executor = new RemoteExecutor($env);
        $ref      = new ReflectionClass($executor);
        $prop     = $ref->getProperty('customCommands');
        $prop->setAccessible(true);
        $customs  = $prop->getValue($executor);

        if (!empty($customs)) {
            echo "Custom Commands (defined in deploy.json):\n";
            foreach (array_keys($customs) as $cmd) {
                echo "  {$cmd}\n";
            }
            echo "\n";
        }
    } catch (\Exception) {
        // Silently skip if config isn't ready
    }

    echo "Examples:\n";
    echo "  vendor/bin/ftp-deploy                # Incremental deploy\n";
    echo "  vendor/bin/ftp-deploy --first-time   # Full deploy (includes vendor/)\n";
    echo "  vendor/bin/ftp-deploy --dry-run      # Preview deployment without applying\n";
    echo "  vendor/bin/ftp-deploy db-reset       # Run custom command set\n";
}

// ─── Run ──────────────────────────────────────────────────────────────────────

try {
    $executor = new RemoteExecutor($config);

    if ($customCommandName) {
        $commands = $executor->getCustomCommand($customCommandName);
        if (!$commands) {
            logColor("ERROR: Custom command '{$customCommandName}' not found in deploy.json", '31');
            exit(1);
        }
        $success = $executor->execute($commands, $dryRun);
    } else {
        $success = $executor->deploy($isFirstTime, $dryRun);
    }

    if ($success) {
        logColor("Process finished successfully.", '32');
    } else {
        logColor("Process failed.", '31');
        exit(1);
    }
} catch (\Exception $e) {
    logColor("ERROR: " . $e->getMessage(), '31');
    exit(1);
}
