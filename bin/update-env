#!/usr/bin/env php
<?php

$autoloadPaths = [
    getcwd() . '/vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../vendor/autoload.php',
];

$loaded = false;
foreach ($autoloadPaths as $file) {
    if (file_exists($file)) {
        require $file;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    die("ERROR: Composer autoloader not found. Please run 'composer install'.\n");
}

use Cyberwizard\LaravelFtpDeployer\RemoteExecutor;

function loadEnv($path)
{
    if (!file_exists($path)) return [];
    $lines = file($path, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    $env = [];
    foreach ($lines as $line) {
        $line = trim($line);
        if (!$line || str_starts_with($line, '#')) continue;
        if (!str_contains($line, '=')) continue;
        [$name, $value] = explode('=', $line, 2);
        $env[trim($name)] = trim($value, '"\' ');
    }
    return $env;
}

$root    = getcwd();
$envFile = file_exists($root . '/.env.prod') ? $root . '/.env.prod' : $root . '/.env';
$env     = loadEnv($envFile);

$config = [
    'ftp_host' => $env['FTP_HOST']     ?? '',
    'ftp_user' => $env['FTP_USERNAME'] ?? '',
    'ftp_pass' => $env['FTP_PASSWORD'] ?? '',
    'ftp_port' => $env['FTP_PORT']     ?? 21,
    'ftp_root' => $env['FTP_ROOT']     ?? '',
    'app_url'  => $env['APP_URL']      ?? '',
];

if (empty($config['ftp_host']) || empty($config['ftp_user'])) {
    die("\033[31mERROR: FTP configuration missing in .env or .env.prod. We need it to connect to the remote server.\033[0m\n");
}

echo "Enter environment variables separated by commas (e.g. KEY1=value1, KEY2=value2): ";
$input = trim(fgets(STDIN));

if (empty($input)) {
    die("Error: Input cannot be empty.\n");
}

$pairs = explode(',', $input);
$variables = [];
foreach ($pairs as $pair) {
    if (str_contains($pair, '=')) {
        [$key, $value] = explode('=', $pair, 2);
        $variables[trim($key)] = trim($value);
    }
}

if (empty($variables)) {
    die("Error: No valid KEY=VALUE pairs found.\n");
}

try {
    $executor = new RemoteExecutor($config);
    if (!$executor->updateRemoteEnv($variables)) {
        exit(1);
    }
} catch (\Exception $e) {
    echo "\033[31mERROR: " . $e->getMessage() . "\033[0m\n";
    exit(1);
}
